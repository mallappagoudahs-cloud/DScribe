e: 'MRD \u0c85\u0ca8\u0cc1\u0cb8\u0cb0\u0ca3\u0cc6 \u0c86\u0ca1\u0cbf\u0c9f\u0ccd',", "        section_sub: '\u0c94\u0cb7\u0ca7\u0c97\u0cb3\u0ca8\u0ccd\u0ca8\u0cc1 \u0cb9\u0cca\u0cb0\u0ca4\u0cc6\u0c97\u0cc6\u0caf\u0cb2\u0cbe\u0c97\u0cbf\u0ca6\u0cc6. \u0cb0\u0cab\u0ccd\u0ca4\u0cc1 \u0cae\u0cbe\u0ca1\u0cc1\u0cb5 \u0cae\u0cca\u0ca6\u0cb2\u0cc1 \u0caf\u0cbe\u0cb5\u0cc1\u0ca6\u0cc7 \u0c95\u0ccd\u0cb7\u0cc7\u0ca4\u0ccd\u0cb0\u0cb5\u0ca8\u0ccd\u0ca8\u0cc1 \u0cb8\u0c82\u0caa\u0cbe\u0ca6\u0cbf\u0cb8\u0cbf.',", "        idle_status: '\u0ca8\u0cbf\u0cb7\u0ccd\u0c95\u0ccd\u0cb0\u0cbf\u0caf. \u0c92\u0c82\u0ca6\u0cc1 \u0c85\u0ca5\u0cb5\u0cbe \u0cb9\u0cc6\u0c9a\u0ccd\u0c9a\u0cbf\u0ca8 \u0cab\u0cc8\u0cb2\u0ccd \u0c85\u0caa\u0ccd\u200c\u0cb2\u0ccb\u0ca1\u0ccd\u200c\u0c97\u0cbe\u0c97\u0cbf \u0c95\u0cbe\u0caf\u0cb2\u0cbe\u0c97\u0cc1\u0ca4\u0ccd\u0ca4\u0cbf\u0ca6\u0cc6.',", "      },", "    };", "", "    let currentLang = 'en';", "", "    function applyLanguage(lang) {", "      currentLang = lang;", "      const t = TRANSLATIONS[lang] || TRANSLATIONS['en'];", "      document.querySelectorAll('[data-i18n]').forEach(el => {", "        const key = el.getAttribute('data-i18n');", "        if (t[key] !== undefined) {", "          if (el.tagName === 'INPUT' || el.tagName === 'TEXTAREA') {", "            el.placeholder = t[key];", "          } else {", "            el.innerHTML = t[key].replace(/\\n/g, '<br>');", "          }", "        }", "      });", "      // Update upload zone text separately (inside the zone div)", "      const uploadLabel = document.querySelector('.upload-label');", "      const uploadHint = document.querySelector('.upload-hint');", "      const processBtn = document.getElementById('processBtn');", "      if (uploadLabel) uploadLabel.textContent = t.upload_label;", "      if (uploadHint) uploadHint.textContent = t.upload_hint;", "      if (processBtn) processBtn.textContent = t.upload_btn;", "    }", "", "    const langSelect = document.getElementById('langSelect');", "    if (langSelect) {", "      langSelect.addEventListener('change', (e) => applyLanguage(e.target.value));", "    }", "", "    /* \u2500\u2500 Manual Drug Form Logic \u2500\u2500 */", "    const mfAddBtn = document.getElementById('mfAddBtn');", "    const mfClearBtn = document.getElementById('mfClearBtn');", "", "    function clearManualForm() {", "      ['mfDrug', 'mfDosage', 'mfTimes', 'mfDuration'].forEach(id => {", "        const el = document.getElementById(id);", "        if (el) el.value = '';", "      });", "      ['mfRoute', 'mfFreq'].forEach(id => {", "        const el = document.getElementById(id);", "        if (el) el.selectedIndex = 0;", "      });", "    }", "", "    if (mfAddBtn) {", "      mfAddBtn.addEventListener('click', () => {", "        const drugName = (document.getElementById('mfDrug').value || '').trim();", "        if (!drugName) {", "          alert('Please enter a Drug Name.');", "          return;", "        }", "        const newEntry = {", "          _id: currentAlerts.length,", "          drug_name: { value: drugName, unclear: false },", "          dosage: { value: document.getElementById('mfDosage').value.trim() || '', unclear: false },", "          route: { value: document.getElementById('mfRoute').value || '', unclear: false },", "          frequency: { value: document.getElementById('mfFreq').value || '', unclear: false },", "          duration_days: document.getElementById('mfDuration').value ? Number(document.getElementById('mfDuration').value) : null,", "          alert_times: document.getElementById('mfTimes').value.split(',').map(t => t.trim()).filter(t => t.length > 0),", "          confidence: 1.0,", "        };", "        currentAlerts.push(newEntry);", "        if (!currentAlerts.length) {", "          document.getElementById('results').style.display = 'block';", "        }", "        alertsPage = 1;", "        renderAlertsTable();", "        updateJsonPreview();", "        clearManualForm();", "        // Show results if hidden", "        document.getElementById('results').style.display = 'block';", "      });", "    }", "", "    if (mfClearBtn) {", "      mfClearBtn.addEventListener('click', clearManualForm);", "    }", "  </script>", "</body>", "</html>", ""]